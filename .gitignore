# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg
*.egg-info/
dist/
build/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.whl
MANIFEST

# ── Virtual environments ──────────────────────────────────────────────────────
.venv/
venv/
env/
ENV/
.env

# ── Environment / secrets ─────────────────────────────────────────────────────
.env
.env.local
.env.*.local
*.secret
secrets.json

# ── Database (user data — never commit, GDPR) ─────────────────────────────────
backend/data/*.db
backend/data/*.db-shm
backend/data/*.db-wal
tests/fixtures/_test.db

# ── ML model weights (large binaries — download at runtime) ──────────────────
*.pt
*.pth
*.onnx
*.ckpt
*.bin
*.safetensors
ml/runs/

# ── HuggingFace / torch cache ─────────────────────────────────────────────────
.cache/
~/.cache/huggingface/
~/.cache/torch/

# ── Uploaded images (never persist user images, NfReq10) ─────────────────────
uploads/
tmp/
*.tmp

# ── IDE & OS ──────────────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ── Pytest / coverage ─────────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
coverage.xml

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
logs/
